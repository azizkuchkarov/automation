{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "atg-platform-secret-key-min-32-chars-long",
    "Issuer": "atg-platform",
    "Audience": "atg-users",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=automation;Username=postgres;Password=postgres"
  },
  "Minio": {
    "Enabled": false,
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "atg-marketing",
    "UseSsl": false
  },
  "Hangfire": {
    "Enabled": true
  },
  "Notifications": {
    "ApprovalReminderAfterDays": 2,
    "ApprovalReminderCooldownHours": 24
  },
  "Ldap": {
    "Enabled": true,
    "Server": "DC03.atg.uz",
    "Port": 389,
    "UseSsl": false,
    "BaseDn": "DC=atg,DC=uz",
    "BindDn": "",
    "BindPassword": "",
    "Domain": "atg.uz",
    "NetBiosName": "ATG"
  }
}
