# PostgreSQL
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# API
API_PORT=5161
JWT_SECRET=atg-platform-secret-key-min-32-chars-long
ASPNETCORE_ENVIRONMENT=Development

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5161

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Notifications (approval reminders via Hangfire)
NOTIFICATIONS_APPROVAL_REMINDER_AFTER_DAYS=2
NOTIFICATIONS_APPROVAL_REMINDER_COOLDOWN_HOURS=24

# E-IMZO
EIMZO_SERVER_PORT=18080
EIMZO_SITE_HOST=unilogin.atg.uz
NEXT_PUBLIC_EIMZO_DOMAIN=unilogin.atg.uz
NEXT_PUBLIC_EIMZO_API_KEY=

# Public IP shown by E-IMZO-SERVER /ping (yourIP) — required for timestamp/verify from Docker
EIMZO_CLIENT_IP=
EIMZO_ALLOW_UNSIGNED_PKCS7=true
